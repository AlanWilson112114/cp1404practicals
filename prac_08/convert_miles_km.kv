BoxLayout:
    orientation: 'vertical'
    padding: 10
    spacing: 10

    BoxLayout:
        orientation: 'horizontal'
        spacing: 10

        TextInput:
            id: input_number
            text: '34'
            font_size: 48
            multiline: False
            size_hint_x: 2

        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 1
            spacing: 10

            Button:
                text: 'Up'
                on_press: app.increment_input(1)
            Button:
                text: 'Down'
                on_press: app.increment_input(-1)

    Button:
        text: 'Convert miles to km'
        size_hint_y: None
        height: 50
        on_press: app.handle_conversion()

    Label:
        id: output_label
        text: app.kilometers
        font_size: 48
        color: (1, 1, 0, 1)  # Yellow text
        size_hint_y: None
        height: 50
